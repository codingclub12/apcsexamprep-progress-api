PORT=4000
JWT_SECRET=CHANGE-THIS-TO-A-LONG-RANDOM-STRING-IN-PRODUCTION
DB_PATH=./progress.db

# Shopify orders/paid webhook signing secret (Shopify admin: the webhook's
# signing secret). Required for the /api/shopify/webhook/orders-paid route to
# verify HMAC. Without it, that route fails closed and rejects every request.
SHOPIFY_WEBHOOK_SECRET=

# Optional JSON override for the SKU-to-course map. Merged over the defaults in
# config/shopify-skus.js (env wins on shared keys). Example:
# SHOPIFY_SKU_MAP={"CSA-FULL-2025":"ap-csa","CYBER-FULL":"ap-cybersecurity"}
SHOPIFY_SKU_MAP=
